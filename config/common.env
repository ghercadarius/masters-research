MINIKUBE_PROFILE=sku-bench
DATAPLANE_MODE=baseline
BASE_CPUS=2
BASE_MEMORY_MB=4096
NAMESPACE=sku-bench
APP_NAME=sample-python-webapp
APP_IMAGE=sku-bench/sample-python-webapp:local
APP_PORT=5000
SERVICE_PORT=80
POD_CPU_REQUEST_MILLICORES=200
POD_CPU_LIMIT_MILLICORES=500
POD_MEMORY_REQUEST_MIB=256
POD_MEMORY_LIMIT_MIB=512
REPLICA_SAFETY_FACTOR=0.8
MAX_REPLICAS_ABSOLUTE=200
TEST_DURATION_SECONDS=10
POWER_SAMPLE_INTERVAL_SECONDS=2
JMETER_THREADS=100
JMETER_RAMP_UP_SECONDS=2
JMETER_WORK_MIN_INTENSITY=2
JMETER_WORK_MAX_INTENSITY=14
JMETER_BATCH_MIN_INTENSITY=2
JMETER_BATCH_MAX_INTENSITY=10
TUNNEL_BIND_ADDRESS=127.0.0.1
TUNNEL_PID_FILE=state/minikube_tunnel.pid
TUNNEL_LOG_FILE=logs/minikube_tunnel.log
RUN_STATE_FILE=state/runtime.env
CONTINUE_ON_ERROR_DEFAULT=true
BUILD_APP_IMAGE=true
CALICO_EBPF_MANIFEST_PATH=
CALICO_EBPF_OPERATOR_MANIFEST_URL=https://raw.githubusercontent.com/projectcalico/calico/v3.30.0/manifests/tigera-operator.yaml
CALICO_EBPF_CUSTOM_RESOURCES_PATH=config/calico-ebpf-custom-resources.yaml
CALICO_EBPF_FELIX_CONFIG_PATH=config/calico-ebpf-felix.yaml
CALICO_EBPF_SKIP_KUBE_PROXY_START=false
CALICO_EBPF_DISABLE_KUBE_PROXY=true
